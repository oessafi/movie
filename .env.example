# OMDb API
OMDB_API_KEYS=cle_1,cle_2,cle_3

# Optional fallback for one key only
# OMDB_API_KEY=ta_cle_api_ici

# Authentication mode:
# - none: no SSO expected
# - header: trusted headers forwarded by a proxy in front of Streamlit
AUTH_MODE=none
AUTH_REQUIRED=false

# Example header order for Keycloak + oauth2-proxy / reverse proxy
AUTH_HEADER_CANDIDATES=x-auth-request-email,x-auth-request-user,x-forwarded-email,x-forwarded-user

# Optional local development fallback when AUTH_MODE=header
# AUTH_DEV_USER=dev@example.com
